PORT=5051
NODE_ENV=production

MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/countpluse?retryWrites=true&w=majority

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=7d

# Allowed frontend origins, comma-separated in production
CORS_ORIGIN=https://your-app.example.com

# OTP behavior
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=30

# Email delivery
EMAIL_PROVIDER=smtp
EMAIL_FROM=your_sender@example.com

# SMTP configuration
EMAIL_SERVICE=gmail
EMAIL_USER=your_sender@example.com
EMAIL_PASSWORD=your_app_password

# SendGrid alternative
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=your_sendgrid_api_key
